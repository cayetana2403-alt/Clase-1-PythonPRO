def get_pokemon_image_url():
    # Hay más de 1000 Pokémon, así que elegimos uno al azar
    pokemon_id = random.randint(1, 1010)

    url = f'https://pokeapi.co/api/v2/pokemon/{pokemon_id}'
    res = requests.get(url)
    data = res.json()

    # Imagen del Pokémon
    image_url = data['sprites']['front_default']
    return image_url

@bot.command('pokemon')
async def pokemon(ctx):
    """Envía un Pokémon aleatorio"""
    image_url = get_pokemon_image_url()

    if image_url:
        await ctx.send(image_url)
    else:
        await ctx.send("No se pudo encontrar la imagen 😢")

def get_meme_image_url():
    url = "https://api.imgflip.com/get_memes"

    try:
        respuesta = requests.get(url)
        datos = respuesta.json()

        if datos["success"]:
            memes = datos["data"]["memes"]
            meme = random.choice(memes)
            return meme["url"]

    except Exception as e:
        print(f"Error: {e}")

    return None

@bot.command("meme")
async def meme(ctx):
    """Envía un meme aleatorio"""

    image_url = get_meme_image_url()

    if image_url:
        embed = discord.Embed(
            title="😂 Meme aleatorio",
            color=discord.Color.random()
        )
        embed.set_image(url=image_url)
        await ctx.send(embed=embed)
    else:
        await ctx.send("No se pudo encontrar un meme 😢")

